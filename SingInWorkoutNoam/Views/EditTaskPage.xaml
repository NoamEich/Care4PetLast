<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SingInWorkoutNoam.Views.EditTaskPage"
             Title="EditTaskPage">
    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <!-- Title -->
            <Label
                Text="Edit Task"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#1E1E1E" />

            <!-- Pet Selection -->
            <Label
                Text="Choose Pet"
                FontSize="16"
                TextColor="#6C63FF" />

            <Picker
                Title="Select pet"
                BackgroundColor="#F7F7F7"
                HeightRequest="55"
                TitleColor="Gray" />

            <!-- Task Description -->
            <Label
                Text="Task Description"
                FontSize="16"
                TextColor="#6C63FF" />

            <Editor
                Placeholder="Enter task details..."
                BackgroundColor="#F7F7F7"
                HeightRequest="120"
                TextColor="Black" />

            <!-- Assign To -->
            <Label
                Text="Assign To"
                FontSize="16"
                TextColor="#6C63FF" />

            <Entry
                Placeholder="Who is responsible?"
                BackgroundColor="#F7F7F7"
                HeightRequest="55"
                TextColor="Black" />

            <!-- Due Date -->
            <Label
                Text="Due Date"
                FontSize="16"
                TextColor="#6C63FF" />

            <DatePicker
                BackgroundColor="#F7F7F7"
                HeightRequest="55"
                TextColor="Black" />

            <!-- Due Time -->
            <Label
                Text="Due Time"
                FontSize="16"
                TextColor="#6C63FF" />

            <TimePicker
                BackgroundColor="#F7F7F7"
                HeightRequest="55"
                TextColor="Black" />

            <!-- Save Button -->
            <Button
                Text="Save Changes"
                BackgroundColor="#6C63FF"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="60"
                CornerRadius="18"
                Margin="0,20,0,0" />

            <!-- Cancel Button -->
            <Button
                Text="Cancel"
                BackgroundColor="Transparent"
                TextColor="#6C63FF"
                FontAttributes="Bold"
                Command="{Binding CancelCommand}"/>

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>