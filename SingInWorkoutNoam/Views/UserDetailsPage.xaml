<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SingInWorkoutNoam.Views.UserDetailsPage"
             Title="UserDetailsPage">

    <Grid>
        <VerticalStackLayout
        Grid.Row="1"
        Grid.Column="1"
        Padding="20"
        Spacing="10">

            <!-- First Name -->
            <Border
            Margin="0,0,0,10"
            Padding="10"
            Stroke="#ccc"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="1">
                <Entry
                FontSize="18"
                Placeholder="First Name"
                TextColor="Wheat" 
                Text="{Binding FirstName}"/>
            </Border>

            <!-- Last Name -->
            <Border
            Margin="0,0,0,10"
            Padding="10"
            Stroke="#ccc"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="1">
                <Entry
                FontSize="18"
                Placeholder="Last Name"
                TextColor="Wheat"
                Text="{Binding LastName}"/>
            </Border>

            <!-- Email -->
            <Border
            Margin="0,0,0,10"
            Padding="10"
            Stroke="#ccc"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="1">
                <Entry
                Keyboard="Email"
                FontSize="18"
                Placeholder="Email"
                TextColor="Wheat"
                Text="{Binding Email}"
                IsEnabled="False"/>
            </Border>

            <!-- Mobile -->
            <Border
            Margin="0,0,0,10"
            Padding="10"
            Stroke="#ccc"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="1">
                <Entry
                Keyboard="Telephone"
                FontSize="18"
                Placeholder="Mobile"
                TextColor="Wheat"
                Text="{Binding Mobile}"/>
            </Border>

            <!-- Update Button -->
            <Button
            x:Name="UpdateButton"
            CornerRadius="8"
            FontSize="20"
            HeightRequest="70"
            Text="Update"
            TextColor="White" 
            Command="{Binding UpdateUserCommand}"/>
            <!--Clicked="UpdateButton_Clicked"-->


        </VerticalStackLayout>

        <!--  מסך טעינה  -->
        <Grid
             HorizontalOptions="Fill"
             IsVisible="{Binding IsBusy}"
             VerticalOptions="Fill">

            <Grid
             HorizontalOptions="Fill"
             IsVisible="{Binding IsBusy}"
             VerticalOptions="Fill">

                <BoxView
             BackgroundColor="LightBlue"
             HorizontalOptions="Fill"
             Opacity="0.7"
             VerticalOptions="Fill" />

                <ActivityIndicator
             IsRunning="True"
             WidthRequest="100"
             Color="Beige" />
            </Grid>
        </Grid>
    </Grid>
    


</ContentPage>